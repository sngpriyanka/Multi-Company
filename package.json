{
  "name": "multi-company-command-center",
  "version": "1.0.0",
  "description": "AI-Powered Multi-Company Command Center - Monorepo",
  "private": true,
  "workspaces": [
    "Backend",
    "Frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "backend:dev": "cd Backend && npm run dev",
    "frontend:dev": "cd Frontend && npm run dev",
    "install:all": "npm install && npm run workspace:install",
    "workspace:install": "npm install --workspaces",
    "build": "npm run workspace:build",
    "workspace:build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": ["monorepo", "mern", "react", "express", "vite", "multi-company", "dashboard"],
  "author": "Multi-Company Command Center Team",
  "license": "MIT"
}
